# Application
APP_ENV=development
DEBUG=True
LOG_LEVEL=debug

# Cohere API Configuration (FREE tier: 1M requests/month)
# Sign up at: https://dashboard.cohere.com/
# Get your key from: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key_here

# Groq API Configuration (FREE tier: 14,400 requests/day)
# Sign up at: https://console.groq.com
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Vector Database (Chroma)
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_COLLECTION_NAME=documents

# API Settings
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# RAG Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=5
CONFIDENCE_THRESHOLD=0.7

# LLM Configuration
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=500

# Embeddings: Using Cohere API (embed-english-v3.0)
# Better quality than local models, 1024 dimensions, FREE tier available
